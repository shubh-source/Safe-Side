<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_dark"
    android:padding="32dp">

    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_heart_vlynxly"
        app:tint="@color/accent_gold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Connection Code"
        android:textSize="28sp"
        android:fontFamily="serif"
        android:textColor="@color/accent_gold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share this code with your guardian.\nBoth must enter the same code."
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="40dp"/>

    <!-- Code Display Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/accent_gold"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <TextView
                android:id="@+id/tvCodeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Christine0109"
                android:textSize="36sp"
                android:fontFamily="monospace"
                android:textColor="@color/accent_gold"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your pair code"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Connect"
        android:textSize="17sp"
        android:textColor="@color/bg_dark"
        android:backgroundTint="@color/accent_gold"
        app:cornerRadius="16dp"
        app:elevation="4dp"/>

</LinearLayout>
