<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/bg_dark">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_shield_vlynxly"
        app:tint="@color/accent_gold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guardian Mode"
        android:textSize="32sp"
        android:fontFamily="serif"
        android:textColor="@color/accent_gold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvProtectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listening for alerts in background"
        android:textSize="15sp"
        android:fontFamily="sans-serif-light"
        android:textColor="@color/accent_purple"
        android:layout_marginBottom="32dp"/>

    <!-- Link Status Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLinkStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/glass_border"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivStatusIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_vlynxly"
                app:tint="@color/text_secondary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verifying Connection..."
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:fontFamily="sans-serif-light"
                android:textSize="18sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvPairCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.8"
                android:layout_marginBottom="4dp"/>
                
            <TextView
                android:id="@+id/tvProtected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Active SOS Emergency Card (hidden by default) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSosAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:strokeWidth="2dp"
        app:strokeColor="@color/sos_red"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 EMERGENCY SOS ACTIVE"
                android:textColor="@color/sos_red"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvSosLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Waiting for GPS location..."
                android:textColor="@color/white"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Action buttons inside SOS Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnSosOpenMap"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Open Map"
                    android:textColor="@color/bg_dark"
                    android:backgroundTint="@color/success"
                    android:layout_marginEnd="6dp"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btnSosCall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Call Partner"
                    android:textColor="@color/bg_dark"
                    android:backgroundTint="@color/accent_gold"
                    android:layout_marginStart="6dp"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSosDismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dismiss SOS Alert"
                android:textColor="@color/white"
                android:backgroundTint="@color/sos_red_dark"
                android:textSize="13sp"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your phone will ring instantly when SOS is triggered"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="8dp"/>

</LinearLayout>
